# ── Database ─────────────────────────────────────
POSTGRES_USER=store_user
POSTGRES_PASSWORD=store_pass
POSTGRES_DB=store_intelligence
DATABASE_URL=postgresql+asyncpg://store_user:store_pass@localhost:5432/store_intelligence
DATABASE_URL_SYNC=postgresql+psycopg2://store_user:store_pass@localhost:5432/store_intelligence

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API general ───────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Detection thresholds (pipeline + API) ─────────
CONFIDENCE_THRESHOLD=0.35
REID_SIMILARITY_THRESHOLD=0.65
DWELL_THRESHOLD_SECONDS=30
FRAME_SKIP=3

# ── Anomaly thresholds ────────────────────────────
QUEUE_SPIKE_THRESHOLD=5
QUEUE_CRITICAL_THRESHOLD=10
CONVERSION_DROP_THRESHOLD_PCT=20
CONVERSION_CRITICAL_DROP_PCT=40
DEAD_ZONE_MINUTES=30
STALE_FEED_MINUTES=10

# ── POS correlation window ────────────────────────
POS_CORRELATION_WINDOW_MINUTES=5

# ── Dashboard ─────────────────────────────────────
API_BASE_URL=http://localhost:8000
DASHBOARD_REFRESH_SECONDS=3